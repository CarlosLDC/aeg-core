# Copy this file to `.env` and fill the values with real credentials (do not commit `.env`).

# Local dev (SPRING_PROFILES_ACTIVE=dev uses application-dev.properties defaults)
# APP_SECURITY_JWT_SECRET=your-jwt-secret-at-least-32-characters-long
# APP_SECURITY_ADMIN_USERNAME=admin@example.com
# APP_SECURITY_ADMIN_PASSWORD=change-me

# Manual Flyway repair (if needed): DATABASE_URL=postgresql://... ./.do/run-flyway-repair.sh

# Production (DigitalOcean App Platform — required, type SECRET)
# APP_SECURITY_JWT_SECRET=
# APP_SECURITY_ADMIN_USERNAME=
# APP_SECURITY_ADMIN_PASSWORD=
# APP_CORS_ALLOWED_ORIGINS=https://aeg-admin.tech,https://www.aeg-admin.tech
MQTT_HOST=your.mqtt.host
MQTT_PORT=1883
MQTT_USER=your_user
MQTT_PASS=your_password

# Optional: full broker URL (overrides MQTT_HOST/MQTT_PORT when set)
# MQTT_URL=tcp://your.mqtt.host:1883

# Subscribe to device telemetry (wildcard supported, e.g. aeg/devices/#)
MQTT_INBOUND_TOPIC=aeg/telemetry/#
# Set to false if the API should only publish (no live monitor)
MQTT_INBOUND_ENABLED=true

# In-memory ring buffer for GET /api/mqtt/messages
MQTT_MONITOR_BUFFER_SIZE=200
MQTT_ENAJENACION_ACTIVITY_BUFFER_SIZE=300
