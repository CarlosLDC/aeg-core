{
  "info": {
    "_postman_id": "d9f7b6d2-7ad8-4b3d-b7f5-9f4d2a4e0c01",
    "name": "AEG Core API (Safe Read-Only)",
    "description": "Coleccion Postman segura (read-only) para diagnostico en cloud. Solo ejecuta requests GET y Auth > Login. No incluye creaciones, actualizaciones ni borrados.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token exists', () => pm.expect(json.token).to.be.a('string'));",
                  "pm.environment.set('adminToken', json.token);",
                  "pm.environment.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has user profile', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('name');",
                  "  pm.expect(json).to.have.property('email');",
                  "  pm.expect(json).to.have.property('username');",
                  "  pm.expect(json).to.have.property('role');",
                  "  pm.expect(json).to.have.property('branchId');",
                  "  pm.expect(json).to.have.property('distributorId');",
                  "  pm.expect(json).to.have.property('enabled');",
                  "  pm.expect(json.email).to.eql(json.username);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "MQTT",
      "description": "Publicación MQTT y monitor en vivo (REST + WebSocket). Ejecuta Auth > Login antes de usar esta carpeta.",
      "item": [
        {
          "name": "Check broker connection",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}{{mqttProbePath}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status code is 200 or 503', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "",
                  "pm.test('Response has probe fields', () => {",
                  "  pm.expect(json).to.have.property('success');",
                  "  pm.expect(json).to.have.property('connected');",
                  "  pm.expect(json).to.have.property('broker');",
                  "  pm.expect(json).to.have.property('durationMs');",
                  "  pm.expect(json).to.have.property('message');",
                  "});",
                  "",
                  "pm.test('Broker matches current configuration', () => {",
                  "  pm.expect(json.broker).to.include('tcp://');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Monitor",
          "description": "Monitor en vivo: un tópico a la vez. 1) Update subscription 2) WebSocket Connect 3) Publish en un tópico que coincida 4) Get messages o ver frames en WebSocket.",
          "item": [
            {
              "name": "Get monitor status",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}{{mqttStatusPath}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Response has monitor fields', () => {",
                      "  pm.expect(json).to.have.property('inboundEnabled');",
                      "  pm.expect(json).to.have.property('subscribedTopic');",
                      "  pm.expect(json).to.have.property('brokerUrl');",
                      "  pm.expect(json).to.have.property('connected');",
                      "  pm.expect(json).to.have.property('bufferedMessageCount');",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get subscription topic",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}{{mqttSubscriptionPath}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Response has topic and active flag', () => {",
                      "  pm.expect(json.topic).to.be.a('string');",
                      "  pm.expect(json.active).to.be.a('boolean');",
                      "});",
                      "if (json.topic) {",
                      "  pm.environment.set('mqttMonitorTopic', json.topic);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get recent messages",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}{{mqttMessagesPath}}?limit={{mqttMessagesLimit}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "",
                      "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Response is an array', () => pm.expect(json).to.be.an('array'));",
                      "if (json.length > 0) {",
                      "  pm.test('Message items have topic and payload', () => {",
                      "    pm.expect(json[0]).to.have.property('topic');",
                      "    pm.expect(json[0]).to.have.property('payload');",
                      "    pm.expect(json[0]).to.have.property('receivedAt');",
                      "  });",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "WebSocket live monitor",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{wsBaseUrl}}{{mqttWsPath}}?token={{token}}",
                "description": "Abre la pestaña WebSocket en Postman y pulsa Connect. El JWT va en query (?token=). Tras conectar, ejecuta Update subscription y Publish; los frames type=message y type=subscription aparecen en Messages. Ping opcional: envía el texto ping."
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const token = pm.environment.get('token');",
                      "pm.test('JWT token is set (run Auth > Login first)', () => {",
                      "  pm.expect(token, 'token missing').to.be.a('string').and.not.empty;",
                      "});",
                      "const base = pm.environment.get('baseUrl') || '';",
                      "const wsBase = pm.environment.get('wsBaseUrl');",
                      "if (!wsBase && base) {",
                      "  pm.environment.set('wsBaseUrl', base.replace(/^http/i, 'ws'));",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Flow - subscribe publish and history",
              "item": [
                {
                  "name": "3. Get recent messages",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{baseUrl}}{{mqttMessagesPath}}?limit={{mqttMessagesLimit}}"
                  },
                  "event": [
                    {
                      "listen": "test",
                      "script": {
                        "type": "text/javascript",
                        "exec": [
                          "const json = pm.response.json();",
                          "pm.test('Status 200', () => pm.response.to.have.status(200));",
                          "pm.test('History is array', () => pm.expect(json).to.be.an('array'));"
                        ]
                      }
                    }
                  ]
                }
              ],
              "description": "Ejecuta esta carpeta con Collection Runner (en orden). Requiere MQTT inbound activo en el servidor y mqttMonitorTopic que coincida con aeg/test/# (p. ej. aeg/test/postman-monitor)."
            }
          ]
        }
      ]
    },
